@@ -343,6 +347,17 @@ int main(int argc, char* argv[]) {
 	  exonEndRange=s.asInt();
   if (stricterMatching)
 	  terminalMatchRange=exonEndRange;
+  // --terminal-delta N : enforce a terminal-end tolerance of N at the
+  // transcript level ONLY, independently of -e/exonEndRange (which stays
+  // tied to exon-level Sn/Sp). Sets terminalStrict so the '~'->'=' promotion
+  // is disabled, making Transcript-level Sn/Sp end-sensitive while
+  // Intron-chain level remains end-agnostic. Does not trigger the other
+  // --strict-match effects.
+  s=args.getOpt("terminal-delta");
+  if (!s.is_empty()) {
+	  terminalMatchRange=s.asInt();
+	  terminalStrict=true;
+  }
 
   s=args.getOpt('d');
   if (!s.is_empty()) tssDist=s.asInt();
