@@ -255,7 +259,7 @@ int main(int argc, char* argv[]) {
 #endif
 
   GArgs args(argc, argv,
-		  "version;help;debug;gids;gidnames;gnames;no-merge;strict-match;"
+		  "version;help;debug;gids;gidnames;gnames;no-merge;strict-match;terminal-delta=;"
